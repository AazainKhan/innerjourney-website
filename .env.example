# Application Environment
APP_ENV=production
APP_DEBUG=false

# Admin Contact
ADMIN_EMAIL=info@innerjourney-with-shanila.com
ADMIN_NAME="Shanila Khan"

# Site Configuration
SITE_NAME="Inner Journey With Shanila"
SITE_URL=https://innerjourney-with-shanila.com

# Mail Configuration (using server's sendmail by default)
MAIL_FROM_NAME="Inner Journey With Shanila"

# MailerLite — newsletter signup (resources page form + home page popup).
# Get the API key under "Integrations → API" in MailerLite. Group ID is
# optional; leave blank to add subscribers to the default list.
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=
